# Django / Render
SECRET_KEY=replace-with-a-long-random-production-secret
DEBUG=False
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
ALLOWED_HOSTS=your-service.onrender.com

# Add the URL of a hosted Expo web app only if you deploy one.
CORS_ALLOWED_ORIGINS=https://your-web-app.example.com
CSRF_TRUSTED_ORIGINS=https://your-web-app.example.com

# Cloudinary: copy this value from the Cloudinary dashboard and keep it secret.
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Email verification
EMAIL_HOST_USER=your-sending-account@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password-without-spaces
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Servista <your-sending-account@gmail.com>

# Google sign-in, if enabled
GOOGLE_OAUTH_CLIENT_IDS=your-client-id.apps.googleusercontent.com
